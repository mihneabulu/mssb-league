---
import Base from '../layouts/Base.astro';
import TeamInline from '../components/TeamInline.astro';
import { data, stadiumName, homeStadium } from '../lib/data';

// Assign played games to schedule slots in date order (double round-robin: each
// pair meets twice, so the earlier unused game fills the earlier round).
const used = new Set<string>();
const rounds = data.schedule.map((rd) => ({
  round: rd.round,
  matchups: rd.matchups.map(([a, b]) => {
    const g = data.games
      .filter((x) => !used.has(x.gameId))
      .sort((x, y) => x.date - y.date)
      .find((x) => (x.away === a && x.home === b) || (x.away === b && x.home === a));
    if (g) used.add(g.gameId);
    return { a, b, game: g };
  }),
}));
const currentRound = rounds.filter((r) => r.matchups.some((m) => m.game)).at(-1)?.round ?? 1;
---
<Base title="Schedule" active="schedule">
  <div class="section-head" style="margin-top:1.4rem"><span class="pill">📅 Schedule</span></div>
  <p class="muted" style="margin-top:-.5rem">{data.season.rounds}-round double round-robin. Home team listed second.</p>

  <div class="rounds">
    {rounds.map((rd) => (
      <section class={`card round ${rd.round === currentRound ? 'is-current' : ''}`}>
        <header class="round-head">
          <span class="round-no">Round {rd.round}</span>
          {rd.round === currentRound && <span class="tag" style="background:var(--gold)">Current</span>}
        </header>
        <div class="matchups">
          {rd.matchups.map((m) => {
            const g = m.game;
            const away = g ? g.away : m.a;
            const home = g ? g.home : m.b;
            const awW = g && g.winner === away;
            const hoW = g && g.winner === home;
            return (
              <div class="mu">
                <div class={`mu-side ${g && !awW ? 'dim' : ''}`}><TeamInline name={away} size={26} bold={!!awW} /></div>
                <div class="mu-mid">
                  {g ? (
                    <span class="scores mono-num">{g.awayScore}<span class="dash">–</span>{g.homeScore}</span>
                  ) : (
                    <span class="vs">@</span>
                  )}
                </div>
                <div class={`mu-side right ${g && !hoW ? 'dim' : ''}`}><TeamInline name={home} size={26} bold={!!hoW} /></div>
                <div class="mu-foot muted">
                  {g
                    ? stadiumName(g.stadiumId)
                    : <><span class="up-dot">•</span> {homeStadium(home)}</>}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .rounds { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.1rem; }
  .round { padding: .9rem 1rem 1.1rem; }
  .round.is-current { border-color: var(--dirt); box-shadow: 4px 4px 0 var(--dirt); }
  .round-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: .6rem; }
  .round-no { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; }
  .matchups { display: flex; flex-direction: column; gap: .55rem; }
  .mu { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: .4rem;
        border: 2px solid #efe4d2; border-radius: 12px; padding: .5rem .6rem; }
  .mu-side { min-width: 0; }
  .mu-side.right { display: flex; justify-content: flex-end; text-align: right; }
  .mu-side.dim { opacity: .6; }
  .mu-mid { text-align: center; }
  .scores { font-family: var(--font-display); font-weight: 700; font-size: 1.1rem; }
  .scores .dash { color: var(--ink-soft); margin: 0 .15rem; }
  .vs { color: var(--ink-soft); font-weight: 700; }
  .mu-foot { grid-column: 1 / -1; text-align: center; font-size: .72rem; }
</style>
