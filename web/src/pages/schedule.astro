---
import Base from '../layouts/Base.astro';
import TeamInline from '../components/TeamInline.astro';
import { data, stadiumName, homeStadium, scheduleWithResults } from '../lib/data';

const { rounds, currentRound } = scheduleWithResults();
---
<Base title="Schedule" active="schedule">
  <div class="section-head" style="margin-top:1.4rem"><span class="pill">📅 Schedule</span></div>
  <p class="muted" style="margin-top:-.5rem">{data.season.rounds}-round double round-robin. Home team listed first (hosts at their stadium).</p>

  <div class="rounds">
    {rounds.map((rd) => (
      <section class={`card round ${rd.round === currentRound ? 'is-current' : ''}`}>
        <header class="round-head">
          <span class="round-no">Round {rd.round}</span>
          {rd.round === currentRound && <span class="tag" style="background:var(--gold)">Current</span>}
        </header>
        <div class="matchups">
          {rd.matchups.map((m) => {
            const g = m.game;
            const away = g ? g.away : m.a;
            const home = g ? g.home : m.b;
            const awW = g && g.winner === away;
            const hoW = g && g.winner === home;
            return (
              <div class="mu">
                <div class={`mu-row ${g && !hoW ? 'dim' : ''}`}>
                  <TeamInline name={home} size={28} bold={!!hoW} />
                  {g ? <span class="mu-score mono-num">{g.homeScore}</span> : <span class="mu-tag muted">home</span>}
                </div>
                <div class={`mu-row ${g && !awW ? 'dim' : ''}`}>
                  <TeamInline name={away} size={28} bold={!!awW} />
                  {g ? <span class="mu-score mono-num">{g.awayScore}</span> : <span class="mu-tag muted">away</span>}
                </div>
                <div class="mu-foot muted">
                  {g ? stadiumName(g.stadiumId) : <><span class="up-dot">•</span> {homeStadium(home)}</>}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}
  </div>
</Base>

<style>
  .rounds { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.1rem; }
  .round { padding: .9rem 1rem 1.1rem; }
  .round.is-current { border-color: var(--dirt); box-shadow: 4px 4px 0 var(--dirt); }
  .round-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: .6rem; }
  .round-no { font-family: var(--font-display); font-weight: 700; font-size: 1.15rem; }
  .matchups { display: flex; flex-direction: column; gap: .55rem; }
  .mu { display: flex; flex-direction: column; gap: .35rem;
        border: 2px solid #efe4d2; border-radius: 12px; padding: .55rem .7rem; }
  .mu-row { display: flex; align-items: center; justify-content: space-between; gap: .5rem; min-width: 0; }
  .mu-row.dim { opacity: .58; }
  .mu-score { font-family: var(--font-display); font-weight: 700; font-size: 1.2rem; flex: none; }
  .mu-tag { font-size: .68rem; text-transform: uppercase; letter-spacing: .5px; flex: none; }
  .mu-foot { text-align: center; font-size: .72rem; border-top: 2px solid #efe4d2; padding-top: .35rem; margin-top: .05rem; }
</style>
